# Supabase 프로젝트 설정에서 복사
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 서버 전용. NEXT_PUBLIC_ 금지, 클라이언트 번들 금지.
SUPABASE_SERVICE_ROLE_KEY=

# (선택 B) 구글 시트 자동 동기화용. 서버 전용.
# GOOGLE_SERVICE_ACCOUNT_JSON은 서비스 계정 JSON을 한 줄 문자열로 (private_key의 \n 그대로 OK).
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEET_ID=

# Vercel Cron 호출 검증. 운영에서는 반드시 임의 문자열로 설정.
CRON_SECRET=
